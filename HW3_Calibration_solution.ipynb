    "from sklearn.multiclass import OneVsRestClassifier, OneVsOneClassifier\n",
    "from sklearn.metrics import f1_score\n",
    "\n",
    "# OvR\n",
    "t0 = time.time()\n",
    "ovr = OneVsRestClassifier(LogisticRegression(max_iter=10000, random_state=42))\n",
    "ovr.fit(X_tr_stu, y_tr_stu)\n",
    "t_ovr = time.time() - t0\n",
    "y_pred_ovr = ovr.predict(X_te_stu)\n",
    "proba_ovr = ovr.predict_proba(X_te_stu)\n",
    "f1_ovr = f1_score(y_te_stu, y_pred_ovr, average='macro')\n",
    "\n",
    "# OvO\n",
    "t0 = time.time()\n",
    "ovo = OneVsOneClassifier(LogisticRegression(max_iter=10000, random_state=42))\n",
    "ovo.fit(X_tr_stu, y_tr_stu)\n",
    "t_ovo = time.time() - t0\n",
    "y_pred_ovo = ovo.predict(X_te_stu)\n",
    "f1_ovo = f1_score(y_te_stu, y_pred_ovo, average='macro')\n",
