    "\n",
    "print(f'Default  profit: {results_default[\"profit\"].mean():.1f} ± {results_default[\"profit\"].std():.1f}')\n",
    "print(f'Optimised profit: {results_opt[\"profit\"].mean():.1f} ± {results_opt[\"profit\"].std():.1f}')\n",
    "\n",
    "t_stat, p_val = stats.ttest_rel(results_opt['profit'], results_default['profit'])\n",
    "print(f'Paired t-test  t={t_stat:.3f}  p={p_val:.4f}')\n",
    "if p_val < 0.05:\n",
    "    print('Improvement is statistically significant at α=0.05')\n",
    "else:\n",
    "    print('No statistically significant difference at α=0.05')"
