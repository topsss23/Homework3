   "id": "ce_gradient",
   "metadata": {},
   "outputs": [],
   "source": [
    "def softmax(x):\n",
    "    x_max = x.max(axis=1, keepdims=True)\n",
    "    e = np.exp(x - x_max)\n",
    "    return e / e.sum(axis=1, keepdims=True)\n",
    "\n",
    "def ce_gradient(X: np.ndarray, W: np.ndarray, y: np.ndarray) -> np.ndarray:\n",
    "    \"\"\"\n",
    "    Gradient of cross-entropy loss w.r.t. W.\n",
    "    \n",
    "    X: (N, D)\n",
    "    W: (D, K)\n",
    "    y: (N,) integer labels in {0, ..., K-1}\n",
    "    \n",
    "    Derivation (one sample i):\n",
    "      a_i = x_i @ W            shape (K,)\n",
    "      p_i = softmax(a_i)        shape (K,)\n",
    "      Loss = -log p_i[y_i]\n",
    "      dLoss/da_i = p_i - one_hot(y_i)    (standard softmax-CE gradient)\n",
    "      dLoss/dW   = x_i^T @ (p_i - one_hot(y_i))  shape (D, K)\n",
    "    \n",
    "    Batched:\n",
    "      P = softmax(X @ W)        (N, K)\n",
    "      P[i, y_i] -= 1            subtract one-hot\n",
    "      grad = X^T @ P / N        (D, K)\n",
    "    \"\"\"\n",
    "    N, K = X.shape[0], W.shape[1]\n",
    "    P = softmax(X @ W)         # (N, K)\n",
    "    P[np.arange(N), y] -= 1    # subtract one-hot\n",
    "    return X.T @ P / N         # (D, K)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "softmax_reg",
   "metadata": {},
   "outputs": [],
   "source": [
    "class SoftmaxRegression:\n",
    "\n",
    "    def __init__(self, lr=1e-2, max_iter=5000):\n",
    "        self.W = None\n",
    "        self.max_iter = max_iter\n",
    "        self.lr = lr\n",
    "\n",
    "    def fit(self, X, y):\n",
    "        N, D = X.shape\n",
    "        K = len(np.unique(y))\n",
    "        self.W = np.zeros((D, K))\n",
    "        for i in range(self.max_iter):\n",
    "            grad = ce_gradient(X, self.W, y)\n",
    "            self.W -= self.lr * grad\n",
    "        return self\n",
    "\n",
    "    def predict_proba(self, X):\n",
    "        return softmax(X @ self.W)\n",
    "\n",
    "    def predict(self, X):\n",
    "        return np.argmax(self.predict_proba(X), axis=1)\n",
    "\n",
    "\n",
    "# Train and compare\n",
    "t0 = time.time()\n",
    "sm = SoftmaxRegression(lr=0.01, max_iter=5000)\n",
    "sm.fit(X_tr_stu, y_tr_stu)\n",
    "t_sm = time.time() - t0\n",
    "\n",
    "y_pred_sm = sm.predict(X_te_stu)\n",
    "proba_sm = sm.predict_proba(X_te_stu)\n",
    "f1_sm = f1_score(y_te_stu, y_pred_sm, average='macro')\n",
    "\n",
    "ce_ovr = custom_ce(proba_ovr, y_te_stu)\n",
    "ce_ovo = custom_ce(ovo.decision_function(X_te_stu), y_te_stu)  # OvO has no predict_proba in simple form\n",
    "ce_sm  = custom_ce(np.log(proba_sm + 1e-15), y_te_stu)  # pass logits: already log-softmax domain\n",
    "\n",
    "# Better: use raw logits for CE\n",
    "ce_sm2 = custom_ce(X_te_stu @ sm.W, y_te_stu)\n",
    "\n",
    "print(f'OvR  macro-F1: {f1_ovr:.4f}  Time: {t_ovr:.2f}s  CE: {ce_ovr:.4f}')\n",
    "print(f'OvO  macro-F1: {f1_ovo:.4f}  Time: {t_ovo:.2f}s')\n",
    "print(f'Softmax macro-F1: {f1_sm:.4f}  Time: {t_sm:.2f}s  CE: {ce_sm2:.4f}')\n",
    "print('\\nAll three models are broadly comparable. Softmax regression is a clean end-to-end multi-class solution.')"
   ]
