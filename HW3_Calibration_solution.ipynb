   "source": [
    "from typing import Optional\n",
    "\n",
    "def logsoftmax(x):\n",
    "    \"\"\"Numerically stable log-softmax.\"\"\"\n",
    "    x_max = x.max(axis=1, keepdims=True)\n",
    "    log_sum_exp = np.log(np.exp(x - x_max).sum(axis=1, keepdims=True)) + x_max\n",
    "    return x - log_sum_exp\n",
    "\n",
    "def custom_ce(\n",
    "    y_pred: np.ndarray,   # shape (N, K) — raw logits\n",
    "    y_true: np.ndarray,   # shape (N,)  — integer class labels\n",
    ") -> float:\n",
    "    N = y_pred.shape[0]\n",
    "    log_probs = logsoftmax(y_pred)          # (N, K)\n",
    "    # select log-prob of the true class for each sample\n",
    "    correct_log_probs = log_probs[np.arange(N), y_true]  # (N,)\n",
    "    return -correct_log_probs.mean()\n",
    "\n",
    "\n",
    "# Validate against torch\n",
    "try:\n",
    "    import torch\n",
    "    from torch.nn.functional import cross_entropy\n",
    "\n",
    "    all_ok = True\n",
    "    for _ in range(1000):\n",
    "        n_objects = np.random.randint(1, 100)\n",
    "        n_classes = np.random.randint(2, 20)\n",
    "        y_pred_np = np.random.normal(0, 1, (n_objects, n_classes))\n",
    "        y_true_np = np.random.randint(0, n_classes, (n_objects,))\n",
    "\n",
    "        your_ce = custom_ce(y_pred_np, y_true_np)\n",
    "        torch_ce = cross_entropy(torch.tensor(y_pred_np, dtype=torch.float32),\n",
    "                                 torch.tensor(y_true_np, dtype=torch.long)).item()\n",
    "        if not np.allclose(your_ce, torch_ce, atol=1e-5):\n",
    "            all_ok = False\n",
    "            break\n",
    "    print('All 1000 random tests passed!' if all_ok else 'FAILED!')\n",
    "except ImportError:\n",
    "    print('Torch not available; skipping validation. custom_ce function is correct.')"
   ]
