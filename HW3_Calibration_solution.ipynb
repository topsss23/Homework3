  {
   "cell_type": "markdown",
   "id": "bonus_calib",
   "metadata": {},
   "source": [
    "##### **Bonus: Author's solution** (0.5 points)\n",
    "\n",
    "Implement a custom Platt scaling calibration. Platt (1999) fits a sigmoid $p = 1/(1 + e^{A \\cdot f + B})$ on held-out scores where $f$ is the raw SVM decision-function value."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "platt",
   "metadata": {},
   "outputs": [],
   "source": [
    "from scipy.special import expit\n",
    "from scipy.optimize import minimize\n",
    "\n",
    "class PlattCalibration:\n",
    "    \"\"\"Platt scaling: fits a logistic function on top of raw decision scores.\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.A = None\n",
    "        self.B = None\n",
    "\n",
    "    def fit(self, scores, y):\n",
    "        \"\"\"scores: raw decision_function output; y: true binary labels.\"\"\"\n",
    "        def neg_log_likelihood(params):\n",
    "            A, B = params\n",
    "            p = expit(A * scores + B)\n",
    "            # clip for numerical stability\n",
    "            p = np.clip(p, 1e-12, 1 - 1e-12)\n",
    "            return -np.mean(y * np.log(p) + (1 - y) * np.log(1 - p))\n",
    "\n",
    "        result = minimize(neg_log_likelihood, x0=[1.0, 0.0], method='BFGS')\n",
    "        self.A, self.B = result.x\n",
    "        return self\n",
    "\n",
    "    def predict_proba(self, scores):\n",
    "        return expit(self.A * scores + self.B)\n",
    "\n",
    "\n",
    "# Use a validation split for fitting Platt parameters\n",
    "X_tr2, X_val, y_tr2, y_val = train_test_split(X_cal_train, y_cal_train, test_size=0.2, random_state=0)\n",
    "\n",
    "svm_base = LinearSVC(C=1.0, max_iter=5000, random_state=42)\n",
    "svm_base.fit(X_tr2, y_tr2)\n",
    "\n",
    "val_scores = svm_base.decision_function(X_val)\n",
    "platt = PlattCalibration().fit(val_scores, y_val)\n",
    "\n",
    "test_scores = svm_base.decision_function(X_cal_test)\n",
    "platt_proba = platt.predict_proba(test_scores)\n",
    "\n",
    "plt.figure(figsize=(7, 6))\n",
    "plot_calibration_curve(y_cal_test, svm_proba, label='SVM (raw)')\n",
    "plot_calibration_curve(y_cal_test, platt_proba, label='SVM + Platt (custom)')\n",
    "plt.plot([0, 1], [0, 1], 'k--', label='Perfect')\n",
    "plt.title('Custom Platt Scaling Calibration')\n",
    "plt.xlabel('Mean predicted probability')\n",
    "plt.ylabel('Fraction of positives')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "print(f'Custom Platt  LogLoss: {log_loss(y_cal_test, platt_proba):.4f}')\n",
    "print(f'Custom Platt  Brier:   {brier_score_loss(y_cal_test, platt_proba):.4f}')"
   ]
  },
