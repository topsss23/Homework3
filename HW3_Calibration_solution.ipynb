    "plt.title('Profit vs. Regularization (random revenue)')\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "best_C_bank = C_grid[np.argmax(mean_profits)]\n",
    "print(f'Best C: {best_C_bank}')"
   ]
