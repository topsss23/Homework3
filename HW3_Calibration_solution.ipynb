    "#### **Task 5. Mean-target Encoding** (1 point)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "mte",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simple mean-target encoding without leakage (computed only on train)\n",
    "def mean_target_encode(X_train, y_train, X_test, cat_cols):\n",
    "    X_tr_enc = X_train.copy()\n",
    "    X_te_enc = X_test.copy()\n",
    "    for col in cat_cols:\n",
    "        mapping = y_train.groupby(X_train[col]).mean()\n",
    "        X_tr_enc[col] = X_train[col].map(mapping)\n",
    "        X_te_enc[col] = X_test[col].map(mapping).fillna(y_train.mean())\n",
    "    return X_tr_enc, X_te_enc\n",
    "\n",
    "start = time.time()\n",
    "cols = X_train_b.columns.tolist()\n",
    "X_tr_mte, X_te_mte = mean_target_encode(X_train_b, y_train_b, X_test_b, cols)\n",
    "lr_mte = LogisticRegression(max_iter=1000, random_state=42)\n",
    "lr_mte.fit(X_tr_mte, y_train_b)\n",
    "elapsed_mte = time.time() - start\n",
    "\n",
    "y_pred_mte = lr_mte.predict_proba(X_te_mte)[:, 1]\n",
    "print(f'Mean-Target Encoding  AUC-PR: {average_precision_score(y_test_b, y_pred_mte):.4f}  Time: {elapsed_mte:.3f}s')"
   ]
