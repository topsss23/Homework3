  {
   "cell_type": "code",
   "execution_count": null,
   "id": "mte_transformer",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.base import BaseEstimator, TransformerMixin\n",
    "\n",
    "class MeanTargetEncoder(BaseEstimator, TransformerMixin):\n",
    "    \"\"\"Vectorised mean-target encoder for a list of categorical columns.\"\"\"\n",
    "\n",
    "    def __init__(self, cat_cols=None):\n",
    "        self.cat_cols = cat_cols  # list of column names to encode\n",
    "\n",
    "    def fit(self, X, y):\n",
    "        X = pd.DataFrame(X) if not isinstance(X, pd.DataFrame) else X\n",
    "        self.global_mean_ = float(np.mean(y))\n",
    "        self.mappings_ = {}\n",
    "        cols = self.cat_cols if self.cat_cols is not None else X.columns.tolist()\n",
    "        for col in cols:\n",
    "            self.mappings_[col] = y.groupby(X[col]).mean()\n",
    "        return self\n",
    "\n",
    "    def transform(self, X):\n",
    "        X = pd.DataFrame(X) if not isinstance(X, pd.DataFrame) else X.copy()\n",
    "        for col, mapping in self.mappings_.items():\n",
    "            X[col] = X[col].map(mapping).fillna(self.global_mean_)\n",
    "        return X\n",
    "\n",
    "# Test inside a pipeline\n",
    "pipeline_mte2 = Pipeline([\n",
    "    ('enc', MeanTargetEncoder(cat_cols=X_train_b.columns.tolist())),\n",
    "    ('lr',  LogisticRegression(max_iter=1000, random_state=42))\n",
    "])\n",
    "pipeline_mte2.fit(X_train_b, y_train_b)\n",
    "y_pred_mte2 = pipeline_mte2.predict_proba(X_test_b)[:, 1]\n",
    "print(f'Vectorised MTE (pipeline)  AUC-PR: {average_precision_score(y_test_b, y_pred_mte2):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "task7",
   "metadata": {},
   "source": [
    "#### **Task 7. Smoothing the counters** (1 point)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "smooth_mte",
   "metadata": {},
   "outputs": [],
   "source": [
    "class SmoothedMeanTargetEncoder(BaseEstimator, TransformerMixin):\n",
    "    \"\"\"Mean-target encoder with global-mean smoothing.\n",
    "    g_j(x) = (count_positive + C * global_mean) / (count + C)\n",
    "    \"\"\"\n",
    "    def __init__(self, cat_cols=None, C=10):\n",
    "        self.cat_cols = cat_cols\n",
    "        self.C = C\n",
    "\n",
    "    def fit(self, X, y):\n",
    "        X = pd.DataFrame(X) if not isinstance(X, pd.DataFrame) else X\n",
    "        self.global_mean_ = float(np.mean(y))\n",
    "        self.stats_ = {}\n",
    "        cols = self.cat_cols if self.cat_cols is not None else X.columns.tolist()\n",
    "        for col in cols:\n",
    "            grp = pd.DataFrame({'y': y.values, 'cat': X[col].values})\n",
    "            stats = grp.groupby('cat')['y'].agg(['sum', 'count'])\n",
    "            stats['smoothed'] = (\n",
    "                (stats['sum'] + self.C * self.global_mean_) /\n",
    "                (stats['count'] + self.C)\n",
    "            )\n",
    "            self.stats_[col] = stats['smoothed']\n",
    "        return self\n",
    "\n",
    "    def transform(self, X):\n",
    "        X = pd.DataFrame(X) if not isinstance(X, pd.DataFrame) else X.copy()\n",
    "        for col, mapping in self.stats_.items():\n",
    "            X[col] = X[col].map(mapping).fillna(self.global_mean_)\n",
    "        return X\n",
    "\n",
    "# Tune C\n",
    "best_C_smooth, best_pr_smooth = None, -np.inf\n",
    "for C_val in [1, 5, 10, 20, 50]:\n",
    "    pipe = Pipeline([\n",
    "        ('enc', SmoothedMeanTargetEncoder(cat_cols=X_train_b.columns.tolist(), C=C_val)),\n",
    "        ('lr', LogisticRegression(max_iter=1000, random_state=42))\n",
    "    ])\n",
    "    pipe.fit(X_train_b, y_train_b)\n",
    "    pr = average_precision_score(y_test_b, pipe.predict_proba(X_test_b)[:, 1])\n",
    "    print(f'C={C_val:4d}  AUC-PR={pr:.4f}')\n",
    "    if pr > best_pr_smooth:\n",
    "        best_pr_smooth, best_C_smooth = pr, C_val\n",
    "\n",
    "print(f'\\nBest C={best_C_smooth}  Best AUC-PR={best_pr_smooth:.4f}')\n",
    "print(f'OHE AUC-PR={average_precision_score(y_test_b, y_pred_ohe):.4f}')"
   ]
