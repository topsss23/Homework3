  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bank_data",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess\n",
    "subprocess.run(['wget', '-q', 'https://archive.ics.uci.edu/ml/machine-learning-databases/00222/bank-additional.zip'])\n",
    "subprocess.run(['unzip', '-q', '-o', 'bank-additional.zip'])\n",
    "\n",
    "df_bank = pd.read_csv('bank-additional/bank-additional-full.csv', sep=';')\n",
    "X_bank = df_bank.drop(columns=['duration', 'y'])\n",
    "y_bank = (df_bank.y == 'yes').astype(int)\n",
    "print(X_bank.shape, y_bank.mean().round(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cv_bank",
   "metadata": {},
   "outputs": [],
   "source": [
    "from collections import defaultdict\n",
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "cat_bank = X_bank.select_dtypes(include='object').columns.tolist()\n",
    "num_bank = X_bank.select_dtypes(include=np.number).columns.tolist()\n",
    "\n",
    "CALL_COST = 2    # cost per call\n",
    "REVENUE   = 10   # revenue if client agrees\n",
    "\n",
    "def compute_profit(y_true, y_pred_binary, revenue=REVENUE, cost=CALL_COST):\n",
    "    \"\"\"Profit = revenue * TP - cost * (TP + FP)\"\"\"\n",
    "    tp = np.sum((y_pred_binary == 1) & (y_true == 1))\n",
    "    fp = np.sum((y_pred_binary == 1) & (y_true == 0))\n",
    "    return revenue * tp - cost * (tp + fp)\n",
    "\n",
    "def cross_validate_bank(\n",
    "    X, y,\n",
    "    n_splits=5,\n",
    "    random_state=42,\n",
    "    threshold=0.5,\n",
    "    C=1.0,\n",
    "    random_revenue=False\n",
    "):\n",
    "    metrics = []\n",
    "    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=random_state)\n",
    "\n",
    "    for train_idx, test_idx in skf.split(X, y):\n",
    "        X_tr, X_te = X.iloc[train_idx], X.iloc[test_idx]\n",
    "        y_tr, y_te = y.iloc[train_idx], y.iloc[test_idx]\n",
    "\n",
    "        prep = ColumnTransformer([\n",
    "            ('ohe', OneHotEncoder(handle_unknown='ignore', sparse_output=False), cat_bank),\n",
    "            ('sc',  StandardScaler(), num_bank)\n",
    "        ])\n",
    "        X_tr_enc = prep.fit_transform(X_tr)\n",
    "        X_te_enc = prep.transform(X_te)\n",
    "\n",
    "        model = LogisticRegression(C=C, max_iter=1000, random_state=42)\n",
    "        model.fit(X_tr_enc, y_tr)\n",
    "\n",
    "        proba = model.predict_proba(X_te_enc)[:, 1]\n",
    "        pred  = (proba >= threshold).astype(int)\n",
    "\n",
    "        auc_pr = average_precision_score(y_te, proba)\n",
    "        auc_roc = roc_auc_score(y_te, proba)\n",
    "\n",
    "        if random_revenue:\n",
    "            revenue_per_client = np.random.uniform(0, 20, size=len(y_te))\n",
    "            tp_mask = (pred == 1) & (y_te.values == 1)\n",
    "            fp_mask = (pred == 1) & (y_te.values == 0)\n",
    "            profit = revenue_per_client[tp_mask].sum() - CALL_COST * pred.sum()\n",
    "        else:\n",
    "            profit = compute_profit(y_te.values, pred)\n",
    "\n",
    "        call_cost_total = CALL_COST * pred.sum()\n",
    "\n",
    "        metrics.append({\n",
    "            'auc_pr': auc_pr,\n",
    "            'auc_roc': auc_roc,\n",
    "            'profit': profit,\n",
    "            'call_cost': call_cost_total,\n",
    "            'n_calls': pred.sum()\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(metrics)\n",
    "\n",
    "# Fixed revenue\n",
    "results_fixed = cross_validate_bank(X_bank, y_bank, random_revenue=False)\n",
    "print('=== Fixed Revenue ($10 per client) ===')\n",
    "print(results_fixed.describe().loc[['mean', 'std']].round(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "random_rev",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Random revenue ~ Uniform(0, 20)\n",
    "results_rand = cross_validate_bank(X_bank, y_bank, random_revenue=True)\n",
    "print('=== Random Revenue ~ Uniform(0, 20) ===')\n",
    "print(results_rand.describe().loc[['mean', 'std']].round(3))\n",
    "print('\\nNote: std of profit increases significantly with random revenue (added stochasticity)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "tune_C",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tune C to maximise random-revenue profit\n",
    "C_grid = [0.01, 0.1, 0.5, 1, 2, 5, 10]\n",
    "mean_profits = []\n",
    "for C_val in C_grid:\n",
    "    res = cross_validate_bank(X_bank, y_bank, C=C_val, random_revenue=True)\n",
    "    mean_profits.append(res['profit'].mean())\n",
    "    print(f'C={C_val:5.2f}  mean profit={res[\"profit\"].mean():.1f}')\n",
